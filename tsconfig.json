{
	"extends": "astro/tsconfigs/strictest",
	"compilerOptions": {
		"lib": ["es2022", "dom", "dom.iterable"],
		"paths": {
			"@/assets/*": ["./src/assets/*"],
			"@/components/*": ["./src/components/*"],
			"@/layouts/*": ["./src/layouts/*"],
			"@/utils": ["./src/utils/index.ts"],
			"@/types": ["./src/types.ts"],
			"@/*": ["./src/*"]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	},
	"exclude": ["node_modules", "**/node_modules/*", ".vscode", "dist"]
}
