---
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "../FormattedDate.astro";
import { openLibraryFetch } from "@/utils/open-library";
import type { getBooks } from "@/utils/open-library";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	post: ReturnType<typeof getBooks>[number] & {
		data: Awaited<ReturnType<typeof openLibraryFetch>>;
	};
	withDesc?: boolean;
};

const props: Props<HTMLTag> = Astro.props;
const post = props.post;
const withDesc: Props<"div">["withDesc"] = props.withDesc ?? false;
const Tag = props.as ?? "div";

if (!post?.olid) {
	throw new Error("No OLID found for this book");
}

const {
	title,
	description,
	cover,
	author: olAuthor,
	publishedDate,
	blurDataURL,
} = post.data as any;

const author = olAuthor ?? "unknown author";

// Use the cached `cover` URL directly. Vercel proxy was causing issues, so
// prefer the original cover URL saved in the cache.
const finalCover = cover ?? null;

const placeholder = blurDataURL ?? null;

const dateTimeOptions: Intl.DateTimeFormatOptions = {
	month: "short",
};
---

<Tag class='group flex w-full flex-col gap-5 sm:flex-row'>
	{
		finalCover && (
			<div class='w-32 shrink-0'>
				<div
					class='ol-cover border-accent/10 overflow-hidden rounded-md border shadow-sm transition-shadow sm:group-hover:shadow-md'
					style={
						placeholder
							? `background-image: url('${placeholder}'); background-size: cover; background-position: center; filter: blur(20px) scale(1.05);`
							: undefined
					}
				>
					<img
						src={finalCover}
						alt={`Cover of ${title} by ${author}`}
						class='h-auto w-full object-cover transition-opacity duration-500 ease-out'
						loading='lazy'
						style={{ opacity: 0 }}
						onload={
							"(function(){this.style.opacity='1'; const p=this.closest('.ol-cover'); if(p) p.style.filter='none';}).call(this)"
						}
					/>
				</div>
			</div>
		)
	}

	<div class='flex flex-1 flex-col'>
		<h3 class='title mb-1 text-xl sm:text-2xl'>
			<a
				class='title transition-colors sm:hover:underline'
				data-astro-prefetch
				href={`/books/${post.olid}/`}
			>
				{title}
			</a>
		</h3>

		<div
			class='mb-3 flex flex-wrap items-center gap-1 border-b border-gray-200 pb-2 text-xs font-semibold sm:gap-2 dark:border-gray-800'
		>
			<span class='text-quote p-1 text-xs font-bold'>
				Author: {author || "unknown"}
			</span>
			{
				publishedDate && (
					<>
						<span class='inline'>|</span>
						<span class='p-1'>
							Publish: {publishedDate}
							{/*
							<!-- Published: <FormattedDate date={publishedDate} dateTimeOptions={dateTimeOptions} /> -->
							 */}
						</span>
					</>
				)
			}
			{
				post.readDate && (
					<>
						<span class='inline'>|</span>
						<span>
							Read: <FormattedDate date={post.readDate} dateTimeOptions={dateTimeOptions} />
						</span>
					</>
				)
			}
		</div>

		{
			withDesc && description && (
				<p class='line-clamp-4 max-w-[90%] border-l-2 py-1 pl-1 text-sm leading-relaxed text-wrap wrap-break-word italic opacity-80'>
					{description}
				</p>
			)
		}
	</div>
</Tag>
