---
import BookPreview from "@/components/blog/BookPreview.astro";
import BaseLayout from "@/components/layout/Base.astro";
import Bookshelf from "@/components/bookshelf.astro";
import Pagination from "@/components/Paginator.astro";
import { getBooks, loadOpenLibraryCache } from "@/utils/open-library";
import type { OpenLibraryResult } from "@/utils/open-library";

type Book = ReturnType<typeof getBooks>[number] & { data: OpenLibraryResult } & {
	navigation: { prev: string; next: string };
};
const data = getBooks();
const cache = loadOpenLibraryCache();
const allBooks = data.map((post, index) => {
	const metadata = cache[post.olid];
	if (!metadata) {
		throw new Error(`Missing cached OpenLibrary data for ${post.olid}`);
	}

	const prev = index > 0 ? `/books?name=${data[index - 1]!.olid}` : null;
	const next = index < data.length - 1 ? `/books?name=${data[index + 1]!.olid}` : null;
	return {
		...post,
		data: metadata,
		navigation: { prev, next },
	} as Book;
});

const meta = {
	title: "Books",
	description:
		"A personal archive of books I’ve read, am reading, or hope to read someday. I don’t read as often anymore, but I still like keeping track of the ones that stay with me.",
};

const nameParam = allBooks[0]!.olid;
const paginationProps = {
	prevUrl: {
		text: `← Previous Books`,
		url: allBooks.find(b => b.olid === nameParam)?.navigation.prev,
	},
	nextUrl: {
		text: `Next Books →`,
		url: allBooks.find(b => b.olid === nameParam)?.navigation.next,
	},
};
---

<BaseLayout meta={meta}>
	<h1 class='title'>Books</h1>
	<div>
		<section class='relative mb-10 w-full' aria-label='Bookshelf'>
			<Bookshelf books={allBooks} />
		</section>
	</div>
	<div class='grid max-w-full gap-y-2 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
		<section aria-label='Blog post list'>
			<ul class='space-y-8 text-start'>
				{
					allBooks.map(p => (
						<li
							class='book-item hidden flex-col flex-wrap gap-2 sm:flex-row [&_q]:basis-full'
							data-olid={p.olid}
							data-prev-url={p.navigation.prev}
							data-next-url={p.navigation.next}
						>
							<BookPreview as='h1' post={p} withDesc />
						</li>
					))
				}
				<li
					id='book-not-found'
					class='hidden flex-col flex-wrap gap-2 sm:flex-row [&_q]:basis-full'
				>
					<h1 class='text-xl'>Book not found</h1>
				</li>
			</ul>
			<Pagination {...paginationProps} />
		</section>
	</div>
</BaseLayout>

<script>
	function updateBooksDisplay() {
		const url = new URL(window.location.href);
		let nameParam = url.searchParams.get("name");
		const items = document.querySelectorAll(".book-item");
		const notFound = document.getElementById("book-not-found");
		const prevNav = document.getElementById("prev-nav") as HTMLAnchorElement;
		const nextNav = document.getElementById("next-nav") as HTMLAnchorElement;

		if (!items.length) return;

		// Default to first book if no "name" query param is present
		if (!nameParam) {
			nameParam = items[0]!.getAttribute("data-olid");
			url.searchParams.set("name", nameParam || "");
			window.history.replaceState({}, "", url);
		}

		let found = false;
		items.forEach(item => {
			if (item.getAttribute("data-olid") === nameParam) {
				item.classList.remove("hidden");
				item.classList.add("flex");
				found = true;

				const prevUrl = item.getAttribute("data-prev-url");
				const nextUrl = item.getAttribute("data-next-url");
				prevNav.href = prevUrl || "#";
				prevNav.classList.toggle("opacity-50", !prevUrl);
				prevNav.classList.toggle("pointer-events-none", !prevUrl);
				nextNav.href = nextUrl || "#";
				nextNav.classList.toggle("opacity-50", !nextUrl);
				nextNav.classList.toggle("pointer-events-none", !nextUrl);
			} else {
				item.classList.add("hidden");
				item.classList.remove("flex");
			}
		});

		if (notFound) {
			if (!found) {
				notFound.classList.remove("hidden");
				notFound.classList.add("flex");
			} else {
				notFound.classList.add("hidden");
				notFound.classList.remove("flex");
			}
		}

		let shelfFound = false;
		const books = Array.from(document.querySelectorAll(".book-btn")) as HTMLElement[];
		books.forEach(btn => {
			if (btn.dataset.olid === nameParam) {
				if (shelfFound) return;
				btn.classList.add("expanded");
				shelfFound = true;
			} else {
				btn.classList.remove("expanded");
			}
		});
	}

	// Run on initial load
	document.addEventListener("DOMContentLoaded", () => updateBooksDisplay());
	// Support for Astro view transitions if enabled
	document.addEventListener("astro:page-load", () => updateBooksDisplay());
	// Support for book clicks - ONLY update display, not shelf expansion
	window.addEventListener("bookshelf-book-changed", () => updateBooksDisplay());
	// Support for browser back/forward
	window.addEventListener("popstate", () => updateBooksDisplay());
</script>
