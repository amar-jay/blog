---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

import BaseLayout from "@/components/layout/Base.astro";
import { getBooks, loadOpenLibraryCache } from "@/utils/open-library";
import { existsSync, readFileSync } from "node:fs";
import { resolve } from "node:path";

export const getStaticPaths = (async () => {
	const books = getBooks();
	const cache = loadOpenLibraryCache();

	return books.map(book => {
		const metadata = cache[book.olid];
		if (!metadata) {
			throw new Error(`Missing cached OpenLibrary data for ${book.olid}`);
		}

		return {
			params: { slug: book.olid },
			props: {
				book: {
					...book,
					data: metadata,
				},
			},
		};
	});
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { book } = Astro.props;
const { data } = book;

const meta = {
	title: data.title,
	description: data.description,
	ogImage: data.cover,
};

const readDate = book.readDate
	? new Intl.DateTimeFormat("en-GB", {
			day: "numeric",
			month: "short",
			year: "numeric",
		}).format(new Date(book.readDate))
	: null;

const placeholder = data.blurDataURL ?? null;

const coverSrc = data.cover;

// Load book note from src/content/books/<olid>.md if present
let noteContent: string | null = null;
const notePath = resolve(process.cwd(), `src/content/books/${book.olid}.md`);
if (existsSync(notePath)) {
	const raw = readFileSync(notePath, "utf8");
	// strip YAML frontmatter if present
	noteContent = raw.replace(/^---[\s\S]*?---\s*/i, "").trim();
} else {
	noteContent = "didn't write notes for this book";
}
---

<BaseLayout meta={meta}>
	<h1 class='title mb-3 sm:mb-1'>
		<a class='text-accent sm:hover:underline' href='/books/'>Books</a>
		<span class='ms-1 me-1'>→</span>
		<span class='title'>{data.title}</span>
	</h1>
		<section class='mt-1 grid gap-8 md:grid-cols-[minmax(0,1fr)_200px] md:items-start'>
			<div class='space-y-6'>
				<header class='space-y-4'>
					<div class='pb-2'>
						{
							data.author && <> <span class='text-quote p-1 text-xs font-bold'>Author: {data.author}</span> | </>
						}
						<span class='p-1 text-xs font-semibold'
							>Published: {data.publishedDate ?? "Unknown"}</span
						>
						|
						<span class='p-1 text-xs font-semibold'>Read: {readDate ?? "Not recorded"}</span>
						<p class='p-1 text-xs font-semibold'>
							<a
								class='text-accent hover:underline'
								href={`https://openlibrary.org/books/${book.olid}`}
								rel='noreferrer'
								target='_blank'
							>
								OpenLibrary
							</a>
						</p>
					</div>
					<div>
						<p class='max-w-[90%] border-y p-1 text-sm text-wrap wrap-break-word opacity-65 text-justify'>
							{data.description}
						</p>
					</div>
				</header>

				<section class='space-y-3'>
					<h2 class='title text-2xl'>My Notes</h2>
					<div class='max-w-3xl leading-7 text-zinc-700 dark:text-zinc-300'>
						{noteContent && noteContent.split(/\n\s*\n/).map(p => <p>{p}</p>)}
					</div>
				</section>
			</div>

			<div class='sticky top-24 self-start'>
				<div
					class='book-cover hidden md:block'
					style={placeholder
						? `background-image: url('${placeholder}'); background-size: cover; background-position: center; filter: blur(18px) saturate(1.05);`
						: undefined}
				>
					<img
						src={coverSrc}
						alt={`Cover of ${data.title}`}
						class='aspect-2/3 h-auto w-full object-cover opacity-0 transition-opacity duration-500 ease-out'
						loading='eager'
						onload={"(function(){this.style.opacity='1'; const p=this.closest('.book-cover'); if(p) p.style.filter='none';}).call(this)"}
					/>
				</div>
			</div>
		</section>
</BaseLayout>
